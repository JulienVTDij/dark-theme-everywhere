{
  "name": "Dark Theme Everywhere",
  "short_name": "Dark Theme",
  "description": "Darkens bright pages for easier night time reading. Unofficial improvement of 'Nicer Inverter'.",
  "version": "6.0.1",
  "manifest_version": 3,

  "permissions": ["storage"],

  "action": {
    "default_icon": "icon38.png",
    "default_title": "Toggle dark theme"
  },

  "background": {
    "service_worker": "background.js"
  },

  "icons": {
    "128": "icon128.png",
    "48": "icon48.png",
    "16": "icon16.png"
  },

  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "match_about_blank": true,
      "js": ["client.js"],
      "css": ["main.css"],
      "run_at": "document_start",
      "all_frames": true
    }
  ],

  "options_page": "options.html",

  "web_accessible_resources": [
    {
      "resources": ["icon38.png", "icon38-light.png"],
      "matches": ["<all_urls>"]
    }
  ]
}